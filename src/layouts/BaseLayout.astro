---
import "../styles/global.css";
import "@fontsource/ibm-plex-mono/400.css";
import Header from "../components/Header.astro";
import Loader from "../components/Loader.astro";
import { navLinks, socials } from "../data/navigation";

const SITE_FALLBACK = "https://aymericfremont.com";
const DEFAULT_OG_IMAGE = "/og-default.png";

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    ogImageAlt?: string;
    noInnerCard?: boolean;
    noOuterFrame?: boolean;
}

const {
    title = "Aymeric Fremont — Designer",
    description = "UX/UI designer and aspiring entrepreneur based in Nantes, France.",
    ogImage,
    ogImageAlt,
    noInnerCard = false,
    noOuterFrame = false,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL(SITE_FALLBACK);
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImageURL = new URL(ogImage ?? DEFAULT_OG_IMAGE, siteOrigin).href;
const resolvedOgImageAlt = ogImageAlt ?? title;

---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#fbfefa" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL.href} />
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:site_name" content="Aymeric Fremont" />
        <meta property="og:locale" content="en_US" />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:image:alt" content={resolvedOgImageAlt} />
        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />
        <meta name="twitter:image:alt" content={resolvedOgImageAlt} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link
            rel="preload"
            href="/fonts/Tangerine-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/TWKLausanne-350.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <title>{title}</title>
        <script
            defer
            src="https://cloud.umami.is/script.js"
            data-website-id="c78092f2-77fd-4462-a428-be1ae7ede712"></script>
    </head>

    <body
        class="bg-lime-1 text-lime-12 flex h-dvh max-h-dvh min-h-0 flex-col overflow-hidden"
    >
        <Loader />

        <a class="skip-link" href="#main-content">Skip to content</a>

        <!-- Outer shell: fills viewport; scroll lives inside main (not document) -->
        <div
            class="relative flex min-h-0 flex-1 flex-col gap-1 md:gap-2 p-2 md:p-4"
        >
            <Header />

            <!-- Mobile menu: inset from tokens (--layout-mobile-menu-top / --layout-mobile-menu-inset) -->
            <div
                id="mobile-menu"
                class="md:hidden absolute z-50 flex flex-col overscroll-contain"
                style="display: none; top: var(--layout-mobile-menu-top); left: var(--layout-mobile-menu-inset); right: var(--layout-mobile-menu-inset); bottom: var(--layout-mobile-menu-inset);"
            >
                <!-- Outer frame: lime-1 bg + border (mirrors main frame) -->
                <div
                    class="flex flex-col flex-1 min-h-0 bg-lime-1 border border-frame-stroke p-1"
                >
                    <!-- Inner frame: dark teal (cyan-12) -->
                    <div
                        class="flex flex-col flex-1 min-h-0 bg-cyan-12 border border-frame-stroke rounded-sm px-2 py-5"
                    >
                        <!-- Nav links: top-left, vertical stack -->
                        <nav class="flex flex-col gap-2 px-3">
                            {
                                navLinks.map((link) => (
                                    <a
                                        href={link.href}
                                        data-hover-shuffle
                                        class="flex items-center min-h-nav-h px-2 py-0.5 rounded-lg text-nav font-regular text-lime-1 font-lausanne"
                                    >
                                        {link.label}
                                    </a>
                                ))
                            }
                        </nav>

                        <!-- Socials: bottom-center -->
                        <div class="flex-1 flex items-end justify-center">
                            <div class="flex items-center">
                                {
                                    socials.map((social, i) => (
                                        <>
                                            <a
                                                href={social.href}
                                                data-hover-shuffle
                                                class="flex items-center min-h-nav-h pl-1 py-0.5 text-nav font-regular text-lime-1 font-lausanne"
                                                target={
                                                    social.href.startsWith(
                                                        "http",
                                                    )
                                                        ? "_blank"
                                                        : undefined
                                                }
                                                rel={
                                                    social.href.startsWith(
                                                        "http",
                                                    )
                                                        ? "noopener noreferrer"
                                                        : undefined
                                                }
                                            >
                                                {social.label}
                                            </a>
                                            {i < socials.length - 1 && (
                                                <span class="text-nav text-lime-1 font-lausanne">
                                                    ,
                                                </span>
                                            )}
                                        </>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main content panel: outer (lime-1 bg) → inner (cyan-1 bg) -->
            <main
                id="main-content"
                tabindex="-1"
                class:list={[
                    "flex min-h-0 flex-1 flex-col",
                    !noInnerCard &&
                        !noOuterFrame &&
                        "bg-lime-1 border border-frame-stroke p-1",
                ]}
            >
                {
                    noInnerCard ? (
                        <slot />
                    ) : (
                        <div class="flex min-h-0 flex-1 flex-col overflow-auto overscroll-y-contain rounded-sm border border-frame-stroke bg-cyan-1">
                            <slot />
                        </div>
                    )
                }
            </main>
        </div>

        <script>
            import {
                initLoadShuffle,
                initTextShuffle,
            } from "../scripts/textShuffle.js";

            initTextShuffle();
            initLoadShuffle();
            document.addEventListener("astro:page-load", () => {
                initTextShuffle();
                initLoadShuffle();
            });

            const menuBtn = document.getElementById("mobile-menu-btn");
            const overlay = document.getElementById("mobile-menu");
            const btnText = document.getElementById("menu-btn-text");

            if (menuBtn && overlay && btnText) {
                const setMenuOpen = (open: boolean) => {
                    const wasOpen = overlay.style.display === "flex";
                    overlay.style.display = open ? "flex" : "none";
                    menuBtn.setAttribute("aria-expanded", String(open));
                    btnText.textContent = open ? "Close Menu" : "Open Menu";
                    if (open) {
                        const first = overlay.querySelector<HTMLElement>(
                            "nav a[href]",
                        );
                        requestAnimationFrame(() => first?.focus());
                    } else if (wasOpen) {
                        menuBtn.focus();
                    }
                };
                setMenuOpen(false);

                menuBtn.addEventListener("click", () => {
                    const isOpen = overlay.style.display === "flex";
                    setMenuOpen(!isOpen);
                });

                document.addEventListener("keydown", (e) => {
                    if (e.key !== "Escape") return;
                    if (overlay.style.display !== "flex") return;
                    e.preventDefault();
                    setMenuOpen(false);
                });
            }
        </script>
    </body>
</html>
