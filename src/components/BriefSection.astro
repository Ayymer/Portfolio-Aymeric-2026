---
interface Props {
  heading: string;
  content: string;
}

const { heading, content } = Astro.props;

const gridClass =
  'grid w-full min-w-0 grid-cols-1 items-start md:grid-cols-[minmax(0,1fr)_minmax(0,1.55fr)] md:gap-x-4 lg:grid-cols-2 lg:gap-x-8';
---

<section class={`${gridClass} gap-y-4 md:gap-y-0`}>
  <h2
    class="text-pretty text-body-lg font-regular text-lime-10 font-lausanne"
  >
    {heading}
  </h2>
  <div
    class="min-w-0 flex flex-col gap-8 text-body font-light text-lime-11 font-lausanne"
  >
    <p class="m-0 whitespace-pre-line">{content}</p>
  </div>
</section>
