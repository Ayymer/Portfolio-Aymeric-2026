---
interface Props {
  heading: string;
  content: string;
}

const { heading, content } = Astro.props;
---

<section
  class="grid w-full min-w-0 max-w-[900px] mx-auto grid-cols-1 gap-y-2 md:grid-cols-[minmax(0,1fr)_minmax(0,1.55fr)] md:gap-x-4 md:gap-y-0 lg:grid-cols-2 lg:gap-x-8"
>
  <h2
    class="text-pretty text-body-lg font-regular text-lime-10 font-lausanne"
  >
    {heading}
  </h2>
  <div
    class="min-w-0 flex flex-col gap-6 text-body-lg font-light text-lime-11 font-lausanne"
  >
    <p class="m-0">{content}</p>
  </div>
</section>
