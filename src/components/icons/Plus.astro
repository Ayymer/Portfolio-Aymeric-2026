---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 24 } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M5 12h14"/>
  <path d="M12 5v14"/>
</svg>
