---
interface Props {
  heading?: string;
  detail: string;
}

const { heading, detail } = Astro.props;
---

<section
  class="grid w-full min-w-0 grid-cols-1 items-start gap-y-6 md:grid-cols-[minmax(0,1fr)_minmax(0,1.55fr)] md:gap-x-4 md:gap-y-0 lg:grid-cols-2 lg:gap-x-8"
>
  {
    heading ? (
      <h2
        class="text-pretty text-body-lg font-regular text-lime-10 font-lausanne"
      >
        {heading}
      </h2>
    ) : (
      <div class="hidden min-w-0 md:block" aria-hidden="true"></div>
    )
  }
  <p
    class="m-0 min-w-0 text-body font-light text-lime-11 font-lausanne whitespace-pre-line"
  >
    {detail}
  </p>
</section>
