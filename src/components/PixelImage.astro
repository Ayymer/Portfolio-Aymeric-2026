---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt?: string;
  width?: number;
  height?: number;
  class?: string;
}

const { src, alt = '', width, height, class: className = '' } = Astro.props;
---

<span class="pixel-image-wrap relative block">
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    data-pixel-image
    class={`opacity-0 w-full h-full object-cover ${className}`}
  />
</span>

<script>
  // Astro deduplicates this script — runs exactly once per page regardless
  // of how many PixelImage components are rendered.

  const FRAME_STEPS = [8, 16, 32, 48, 96, 128];
  const FRAME_MS    = 80;
  const MAX_SIZE    = 128;

  function runPixelAnimation(img: HTMLImageElement): void {
    const wrap = img.parentElement as HTMLElement;

    // Size canvas at capped intrinsic resolution for perf.
    let cW = img.naturalWidth;
    let cH = img.naturalHeight;
    if (cW > MAX_SIZE) { cH = Math.round(cH * MAX_SIZE / cW); cW = MAX_SIZE; }

    const canvas = document.createElement('canvas');
    canvas.width  = cW;
    canvas.height = cH;
    canvas.classList.add('rendering-pixelated');
    Object.assign(canvas.style, {
      position: 'absolute', inset: '0',
      width: '100%', height: '100%',
      pointerEvents: 'none',
    });
    wrap.appendChild(canvas);

    const ctx = canvas.getContext('2d')!;
    let stepIndex = 0;

    function drawFrame(): void {
      if (stepIndex >= FRAME_STEPS.length) {
        // Reveal real img, then remove canvas once it's composited.
        img.classList.remove('opacity-0');
        setTimeout(() => canvas.remove(), 100);
        return;
      }

      const cols = FRAME_STEPS[stepIndex];
      const rows = Math.max(1, Math.round(cols * cH / cW));

      ctx.clearRect(0, 0, cW, cH);
      // Pass 1: downscale image to cols×rows
      ctx.imageSmoothingEnabled = true;
      ctx.drawImage(img, 0, 0, cols, rows);
      // Pass 2: upscale with nearest-neighbor (blocky pixels)
      ctx.imageSmoothingEnabled = false;
      ctx.drawImage(canvas, 0, 0, cols, rows, 0, 0, cW, cH);

      stepIndex++;
      setTimeout(drawFrame, FRAME_MS);
    }

    drawFrame();
  }

  function initImage(img: HTMLImageElement): void {
    img.dataset.pixelObserved = 'true';
    if (img.complete && img.naturalWidth > 0) {
      runPixelAnimation(img);
    } else {
      img.addEventListener('load', () => runPixelAnimation(img), { once: true });
    }
  }

  const observer = new IntersectionObserver(
    (entries, obs) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        obs.unobserve(entry.target);
        initImage(entry.target as HTMLImageElement);
      }
    },
    { rootMargin: '0px 0px 120px 0px' }
  );

  function observeNew(): void {
    document.querySelectorAll<HTMLImageElement>(
      '[data-pixel-image]:not([data-pixel-observed])'
    ).forEach(img => {
      img.dataset.pixelObserved = 'true';
      observer.observe(img);
    });
  }

  observeNew();
  document.addEventListener('pixel-images:added', observeNew);
  document.addEventListener('astro:page-load', observeNew);
</script>
