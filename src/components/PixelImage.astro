---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt?: string;
  width?: number;
  height?: number;
  class?: string;
}

const {
  src,
  alt = '',
  width = src.width,
  height = src.height,
  class: className = '',
} = Astro.props;
---

<span class="pixel-image-wrap relative block">
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    data-pixel-image
    class={`opacity-0 w-full h-full object-cover ${className}`}
  />
</span>

<script>
  // Astro deduplicates this script — runs exactly once per page regardless
  // of how many PixelImage components are rendered.

  import { runPixelReveal } from '../scripts/pixelReveal.ts';

  function runPixelAnimation(img: HTMLImageElement): void {
    const wrap = img.parentElement as HTMLElement;
    runPixelReveal(img, wrap, {
      onComplete: () => img.classList.remove('opacity-0'),
      useUtilityPixelClass: true,
    });
  }

  function initImage(img: HTMLImageElement): void {
    img.dataset.pixelObserved = 'true';
    if (img.complete && img.naturalWidth > 0) {
      runPixelAnimation(img);
    } else {
      img.addEventListener('load', () => runPixelAnimation(img), { once: true });
    }
  }

  const observer = new IntersectionObserver(
    (entries, obs) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        obs.unobserve(entry.target);
        initImage(entry.target as HTMLImageElement);
      }
    },
    { rootMargin: '0px 0px 120px 0px' }
  );

  function observeNew(): void {
    document.querySelectorAll<HTMLImageElement>(
      '[data-pixel-image]:not([data-pixel-observed])'
    ).forEach(img => {
      img.dataset.pixelObserved = 'true';
      observer.observe(img);
    });
  }

  observeNew();
  document.addEventListener('pixel-images:added', observeNew);
  document.addEventListener('astro:page-load', observeNew);
</script>
