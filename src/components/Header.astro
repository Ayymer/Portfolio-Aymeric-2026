---
const navLinks = [
  { label: 'Home',  href: '/' },
  { label: 'Works', href: '/works' },
  { label: 'Lab',   href: '/lab' },
  { label: 'About', href: '/about' },
];

const socials = [
  { label: 'Email',     href: 'mailto:hello@aymericfremont.com' },
  { label: 'Instagram', href: 'https://instagram.com/' },
  { label: 'Linkedin',  href: 'https://linkedin.com/in/' },
];

const currentPath = Astro.url.pathname;
---

<header class="flex items-center justify-between shrink-0 w-full" style="height: 36px;">
  <!-- Navbar: logo + nav links -->
  <nav class="flex items-center">
    <!-- Logo -->
    <a href="/" class="shrink-0 mr-1" aria-label="Aymeric Fremont">
      <img src="/logo.svg" alt="AF" width="43" height="24" />
    </a>

    {navLinks.map((link) => {
      const isActive = currentPath === link.href ||
        (link.href !== '/' && currentPath.startsWith(link.href));
      return isActive ? (
        <span
          class="flex items-center justify-center min-h-[36px] px-2 py-0.5 rounded-lg text-[16px] leading-6 font-[350] text-lime-12"
          style="font-family: var(--font-lausanne);"
        >
          {link.label}
        </span>
      ) : (
        <a
          href={link.href}
          class="flex items-center justify-center min-h-[36px] px-2 py-0.5 rounded-lg text-[16px] leading-6 font-[350] opacity-50 hover:opacity-100 transition-opacity text-ghost-fg"
          style="font-family: var(--font-lausanne);"
        >
          {link.label}
        </a>
      );
    })}
  </nav>

  <!-- Socials -->
  <div class="flex items-center">
    {socials.map((social, i) => (
      <span class="flex items-center">
        <a
          href={social.href}
          class="flex items-center justify-center min-h-[36px] px-1 py-0.5 text-[16px] leading-6 font-[350] text-ghost-fg hover:text-lime-12 transition-colors"
          style="font-family: var(--font-lausanne);"
          target={social.href.startsWith('http') ? '_blank' : undefined}
          rel={social.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          {social.label}
        </a>
        {i < socials.length - 1 && (
          <span class="text-[16px] leading-6 text-ghost-fg" style="font-family: var(--font-lausanne);">,</span>
        )}
      </span>
    ))}
  </div>
</header>
