---
import { navLinks, socials } from '../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="flex items-center justify-between shrink-0 w-full" class="h-nav-h">
  <!-- Navbar: logo + nav links (nav links hidden on mobile) -->
  <nav class="flex items-center">
    <!-- Logo: always visible -->
    <a href="/" class="shrink-0 mr-1" aria-label="Aymeric Fremont">
      <img src="/Logo_Small.svg" alt="AF" width="43" height="24" />
    </a>

    {navLinks.map((link) => {
      const isActive = currentPath === link.href ||
        (link.href !== '/' && currentPath.startsWith(link.href));
      return isActive ? (
        <span
          data-hover-shuffle
          class="hidden md:flex items-center justify-center min-h-nav-h px-2 py-0.5 rounded-lg text-[16px] leading-6 font-regular text-lime-12"        >
          {link.label}
        </span>
      ) : (
        <a
          href={link.href}
          data-hover-shuffle
          class="hidden md:flex items-center justify-center min-h-nav-h px-2 py-0.5 rounded-lg text-[16px] leading-6 font-regular opacity-50 hover:opacity-100 transition-opacity text-ghost-fg"        >
          {link.label}
        </a>
      );
    })}
  </nav>

  <!-- Right side: socials on desktop, "Open Menu" on mobile -->
  <div class="flex items-center">
    <!-- Socials: desktop only -->
    <div class="hidden md:flex items-center">
      {socials.map((social, i) => (<><a
          href={social.href}
          data-hover-shuffle
          class="flex items-center justify-center min-h-nav-h pl-1 py-0.5 text-[16px] leading-6 font-regular text-ghost-fg hover:opacity-50 transition-opacity"          target={social.href.startsWith('http') ? '_blank' : undefined}
          rel={social.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >{social.label}</a>{i < socials.length - 1 && <span class="text-[16px] leading-6 text-ghost-fg">,</span>}</>))}
    </div>

    <!-- Mobile menu button: mobile only -->
    <button
      id="mobile-menu-btn"
      class="flex md:hidden items-center justify-center min-h-nav-h px-2 py-0.5 rounded-lg text-[16px] leading-6 font-regular text-ghost-fg"
      style="background: none; border: none; cursor: pointer;"
      aria-label="Toggle menu"
    >
      <span id="menu-btn-text" data-hover-shuffle>Open Menu</span>
    </button>
  </div>
</header>
