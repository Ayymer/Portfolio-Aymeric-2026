---
import PixelImage from './PixelImage.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  src?: ImageMetadata;
  alt?: string;
  /** Cyan plate + object-contain for mockups exported on white/black. */
  cyanMat?: boolean;
}

const { src, alt = '', cyanMat = false } = Astro.props;
---

{src ? (
  cyanMat ? (
    <div class="case-image-mat relative w-full shrink-0 overflow-hidden bg-cyan-2 p-4 md:p-6">
      <div class="case-image-slot case-image-slot--contain">
        <div class="case-image-slot-sizer" aria-hidden="true"></div>
        <PixelImage src={src} alt={alt} />
      </div>
    </div>
  ) : (
    <div class="case-image-slot case-image-slot--cover relative w-full shrink-0 overflow-hidden">
      <div class="case-image-slot-sizer" aria-hidden="true"></div>
      <PixelImage src={src} alt={alt} />
    </div>
  )
) : (
  <div class="case-image-slot relative w-full shrink-0 overflow-hidden bg-placeholder">
    <div class="case-image-slot-sizer" aria-hidden="true"></div>
  </div>
)}

<style is:global>
  /*
    Case study frame: padding-bottom sizer gives a real in-flow height in flex columns.
    Image + canvas sizing is fully specified here so Tailwind preflight (img max-width / height:auto)
    cannot fight utility classes.
  */
  .case-image-slot {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .case-image-slot-sizer {
    display: block;
    width: 100%;
    height: 0;
    padding-bottom: calc(675.75 / 901 * 100%);
    pointer-events: none;
  }

  .case-image-slot .pixel-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .case-image-slot img[data-pixel-image] {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    object-position: center;
  }

  .case-image-slot--cover img[data-pixel-image] {
    object-fit: cover;
  }

  .case-image-slot--contain img[data-pixel-image] {
    object-fit: contain;
  }

  .case-image-slot .pixel-image-wrap canvas {
    z-index: 1;
  }
</style>
