---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Aymeric Fremont — Designer" noOuterFrame>
  <div class="relative min-h-full" data-home-grid-root>
    <canvas
      class="pointer-events-none absolute inset-0 z-0 h-full w-full"
      aria-hidden="true"
      data-home-grid-canvas></canvas>
    <div class="relative z-10 p-5">
      <div class="max-w-[552px]">
        <h1 class="sr-only">Aymeric Fremont</h1>
        <p class="text-body-lg font-regular text-lime-11 text-pretty">
          Aymeric Fremont <sup class="text-nav">(b. 2002, France)</sup>, a designer
          and maker, moves between UX, brand, and front-end with an obsession for
          justified detail. He builds at the intersection of craft and ethics, for
          products that should exist and work beautifully.
        </p>
      </div>
    </div>
  </div>

  <script>
    import { mountHomeGrid } from "../scripts/homeGridPage.ts";

    mountHomeGrid();
    document.addEventListener("astro:page-load", mountHomeGrid);
  </script>
</BaseLayout>
