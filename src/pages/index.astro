---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParticlesSwarm from '../components/ParticlesSwarm.astro';
---

<BaseLayout title="Aymeric Fremont — Designer">
  <!-- position:relative is the drag boundary for the widget and swarm container -->
  <div class="relative h-full">
    <!-- Full-frame background canvas -->
    <ParticlesSwarm />

    <!-- Bio text overlay -->
    <div class="absolute inset-0 p-5 pointer-events-none">
      <div class="max-w-[552px] pointer-events-auto">
        <p class="text-[24px] leading-[27px] font-regular text-lime-11">
          Aymeric Fremont <sup>(b. 2002, France)</sup>, a designer and maker, moves between UX, brand, and front-end with an obsession for justified detail. He builds at the intersection of craft and ethics, for products that should exist and work beautifully.
        </p>
      </div>
    </div>

  </div>
</BaseLayout>
