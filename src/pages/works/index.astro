---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectSidebar from '../../components/ProjectSidebar.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<BaseLayout title="Works — Aymeric Fremont" noInnerCard>
  <h1 class="sr-only">Works</h1>
  <div class="flex min-h-0 flex-1 gap-3 lg:gap-4">

    <!-- Left column: full width on mobile, fixed 459px on desktop -->
    <ProjectSidebar
      projects={projects}
      class="w-full md:w-sidebar md:shrink-0"
    />

    <!-- ─── Desktop right column (hidden on mobile) ─────────────────── -->
    <div class="hidden md:flex flex-col flex-1 min-w-0 gap-[2px] p-1 bg-lime-1 border border-frame-stroke">

      <!-- Section label (layout matches project page: title + ×-width spacer) -->
      <div
        id="right-label"
        class="hidden w-full min-w-0 items-center justify-between px-1 h-6"
      >
        <span
          id="right-heading"
          class="min-w-0 truncate text-mono-sm text-lime-12 font-mono"
        ></span>
        <span
          class="invisible pointer-events-none shrink-0 text-mono-sm font-mono"
          aria-hidden="true"
        >×</span>
      </div>
      <div id="right-spacer" class="h-6 shrink-0"></div>

      <!-- Idle: same grid trail as home; covered when hover preview is open -->
      <div class="relative flex min-h-0 flex-1 flex-col">
        <div
          class="relative flex min-h-0 flex-1 flex-col overflow-hidden rounded-sm border border-frame-stroke bg-cyan-1"
        >
          <div class="absolute inset-0" data-works-grid-root aria-hidden="true">
            <canvas
              class="pointer-events-none absolute inset-0 z-0 h-full w-full"
              aria-hidden="true"
              data-home-grid-canvas></canvas>
          </div>
          <div
            id="right-preview"
            class="absolute inset-0 z-10 flex min-h-0 flex-col items-center justify-center overflow-hidden bg-cyan-1"
            style="display: none;"
          >
            <span
              id="preview-wrap"
              class="relative block"
              style="width: 60%; aspect-ratio: 901/675.75;"
            >
              <img
                id="preview-thumb"
                width="902"
                height="676"
                loading="lazy"
                decoding="async"
                alt=""
                class="object-contain h-full w-full"
                style="opacity: 0;"
              />
            </span>
          </div>
        </div>
      </div>

    </div>

  </div>
</BaseLayout>

<script>
  import '../../scripts/worksIndexPreview.js';
</script>
