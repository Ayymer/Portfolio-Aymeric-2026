---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectSidebar from '../../components/ProjectSidebar.astro';
import CaseImage from '../../components/CaseImage.astro';
import BriefSection from '../../components/BriefSection.astro';
import TwoColumnSection from '../../components/TwoColumnSection.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const allProjects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const { Content } = await render(project);
const hasClosingMarkdown = Boolean(project.body?.trim());
const ogImage = project.data.sections?.[0]?.image?.src ?? project.data.coverImage?.src;
const projectDescription =
  project.data.description ??
  `${project.data.title}: ${project.data.services.join(' · ')} — case study by Aymeric Fremont.`;
const caseImageCyanMat = project.data.caseImageCyanMat ?? false;
---

<BaseLayout
  title={`${project.data.title} — Aymeric Fremont`}
  description={projectDescription}
  ogImage={ogImage}
  ogImageAlt={`${project.data.title} — preview`}
  noInnerCard
>
  <div class="flex min-h-0 flex-1 gap-3 lg:gap-4">

    <!-- Left column: file explorer (hidden on mobile) -->
    <ProjectSidebar
      projects={allProjects}
      activeId={project.id}
      class="hidden md:flex w-sidebar shrink-0"
    />

    <!-- Right column: project detail -->
    <div class="flex flex-col flex-1 min-w-0 gap-3xs p-1 bg-lime-1 border border-frame-stroke">

      <!-- Section label -->
      <div class="flex items-center justify-between px-1 h-6">
        <div class="flex min-w-0 flex-1 items-center gap-2">
          <a
            href="/works"
            class="md:hidden shrink-0 text-nav font-mono text-lime-11 transition-colors hover:text-lime-12 motion-reduce:transition-none"
            aria-label="Back to works"
          >
            &larr;
          </a>
          <span
            class="min-w-0 truncate text-mono-sm text-lime-12 font-mono"
            data-load-shuffle
          >
            / {project.data.title}
          </span>
        </div>
        <a
          href="/works"
          class="shrink-0 text-lg leading-none font-mono text-lime-12 transition-colors hover:text-lime-10 motion-reduce:transition-none"
          aria-label="Close project"
        >
          &times;
        </a>
      </div>

      <!-- Inner card: scrollable content -->
      <div class="flex-1 min-h-0 overflow-auto bg-cyan-1 border border-frame-stroke rounded-sm px-lg pt-12 pb-sm md:px-xl scroll-hide">
        <div class="flex flex-col gap-12 pb-xl w-full min-w-0">

        <!-- Title + metadata: one row from md (title left, meta right) -->
        <div
          class="flex w-full min-w-0 flex-col gap-6 md:flex-row md:items-start md:justify-between md:gap-8"
        >
          <h1
            class="text-display min-w-0 font-book text-lime-11 tracking-[-1.5px] font-lausanne text-balance md:flex-1"
          >
            {project.data.title}
          </h1>
          <div
            class="flex w-full min-w-0 max-w-(--width-meta-table) shrink-0 flex-col ms-auto md:ms-0"
          >
            <div
              class="grid grid-cols-[auto_minmax(0,1fr)] items-center gap-x-1.5 md:gap-x-2 lg:gap-x-6 py-1 lg:py-[6px] border-b border-dashed border-lime-11"
            >
              <span class="shrink-0 text-mono-sm text-lime-11 font-mono">(YEAR)</span>
              <span class="min-w-0 text-right text-mono-sm text-lime-11 font-mono">{project.data.year}</span>
            </div>
            <div
              class="grid grid-cols-[auto_minmax(0,1fr)] items-start gap-x-1.5 md:gap-x-2 lg:gap-x-6 py-1 lg:py-[6px] border-b border-dashed border-lime-11"
            >
              <span class="shrink-0 text-mono-sm text-lime-11 font-mono">(SERVICES)</span>
              <span class="min-w-0 text-right text-mono-sm text-lime-11 font-mono wrap-break-word">
                {project.data.services.map((s, i) => (
                  <>{s}{i < project.data.services.length - 1 && <br />}</>
                ))}
              </span>
            </div>
          </div>
        </div>

        {project.data.sections ? (
          <!-- Case study layout -->
          <div class="flex flex-col gap-12">
            {project.data.sections.map((section, i) => {
              const sections = project.data.sections!;
              const isLast = i === sections.length - 1;
              return (
                <>
                  {/* Insert closing image + tools paragraph before the last section */}
                  {isLast && project.data.closingImage && (
                    <>
                      <CaseImage
                        src={project.data.closingImage}
                        alt={project.data.title}
                        cyanMat={caseImageCyanMat}
                      />
                      {hasClosingMarkdown && (
                        <section class="w-full min-w-0">
                          <div
                            class="flex flex-col gap-8 text-body font-light text-lime-11 font-lausanne whitespace-pre-line prose-project"
                          >
                            <Content />
                          </div>
                        </section>
                      )}
                    </>
                  )}

                  <CaseImage
                    src={section.image}
                    alt={section.type === 'image-only' ? project.data.title : section.heading}
                    cyanMat={caseImageCyanMat}
                  />

                  {section.type === 'brief' ? (
                    <BriefSection
                      heading={section.heading}
                      content={section.content}
                    />
                  ) : section.type === 'two-column' ? (
                    <TwoColumnSection heading={section.heading} detail={section.detail} />
                  ) : null /* image-only */}
                </>
              );
            })}
          </div>
        ) : (
          <!-- Fallback: simple layout for projects without sections -->
          <>
            {project.data.coverImage ? (
              <Image
                src={project.data.coverImage}
                alt={project.data.title}
                width={project.data.coverImage.width}
                height={project.data.coverImage.height}
                class="w-full rounded-sm shrink-0 object-cover max-h-[624px]"
              />
            ) : (
              <div class="w-full bg-placeholder rounded-sm shrink-0" style="height: 624px;"></div>
            )}

            <section
              class="grid w-full min-w-0 grid-cols-1 items-start gap-y-2 pb-6 md:grid-cols-[minmax(0,1fr)_minmax(0,1.55fr)] md:gap-x-4 md:gap-y-0 lg:grid-cols-2 lg:gap-x-8"
            >
              <h2
                class="text-pretty text-body-lg font-regular text-lime-10 font-lausanne"
              >
                About
              </h2>
              <div
                class="min-w-0 flex flex-col gap-8 text-body font-light text-lime-11 font-lausanne prose-project"
              >
                <Content />
              </div>
            </section>

            {project.data.secondaryImage ? (
              <Image
                src={project.data.secondaryImage}
                alt={`${project.data.title} — detail`}
                width={project.data.secondaryImage.width}
                height={project.data.secondaryImage.height}
                class="w-full rounded-sm shrink-0 object-cover max-h-[326px]"
              />
            ) : (
              <div class="w-full bg-placeholder rounded-sm shrink-0" style="height: 326px;"></div>
            )}
          </>
        )}

        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style is:global>
  .scroll-hide {
    scrollbar-width: none;
  }
  .scroll-hide::-webkit-scrollbar {
    display: none;
  }

  .prose-project p {
    margin: 0;
  }

  .prose-project a {
    text-decoration: underline;
    text-underline-offset: 2px;
    color: var(--color-lime-10, inherit);
    transition: color 150ms ease;
  }

  .prose-project a:hover {
    color: var(--color-lime-11, inherit);
  }

  @media (prefers-reduced-motion: reduce) {
    .prose-project a {
      transition: none;
    }
  }
</style>
